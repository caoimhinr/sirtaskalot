{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@sirtaskalot/shared": ["packages/shared/src/index.ts"],
      "@sirtaskalot/db": ["packages/db/src/index.ts"],
      "@sirtaskalot/telemetry": ["packages/telemetry/src/index.ts"]
    }
  }
}
